{
  "permissions": {
    "allow": [
      "Bash(mkdir -p \".agents/skills/fangcun-write/tools/writing_assistant/prompts\")",
      "Bash(touch \".agents/skills/fangcun-write/tools/writing_assistant/__init__.py\")",
      "Bash(head -30 fangcun)",
      "Bash(file fangcun *)",
      "Bash(python -m pytest tests/ -v --tb=short)",
      "Bash(python -m pytest tests/test_state_manager.py::test_phase_lifecycle tests/test_state_manager.py::test_run_history tests/test_state_manager.py::test_resume_phase -v --tb=long)",
      "Bash(python -c \"import os; os.remove\\('c:/Users/Administrator/Documents/trae_projects/fangcun-write/.agents/skills/fangcun-write/tools/tool_calling.py'\\)\")",
      "Bash(python -c ' *)",
      "Bash(python -c \"import sys; sys.path.insert\\(0, '.agents/skills/fangcun-write/tools'\\); from writer import write_chapter, main; print\\('writer.py OK'\\)\")"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/detect-fangcun-gaps.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-end.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-fangcun-commit.sh",
            "if": "Bash(git commit*)",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-outline-before-prose.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-compact.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-compact.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
