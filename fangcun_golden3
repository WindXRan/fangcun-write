#!/usr/bin/env python3
"""黄金三章 — 逐章 guides→write→compare，不达标自动重写。"""

import sys, os, json, subprocess
from pathlib import Path

ROOT = Path(__file__).parent
PIPE = str(ROOT / ".agents/skills/fangcun-write/tools/pipeline.py")


def find_config(project: str) -> str:
    """根据项目路径找对应 config 文件。"""
    best = ""
    for cf in sorted((ROOT / "configs").glob("*.json")):
        cfg = json.loads(cf.read_text(encoding="utf-8"))
        rw = cfg.get("project_dir", "")
        if rw and rw in project:
            return str(cf)
        if project and rw.endswith(Path(project).name):
            best = str(cf)
    return best or "configs/test_10ch_v2.json"


def run_phase(config: str, phase: str, ch: int) -> bool:
    args = ["python", PIPE, "--config", config, "--phase", phase,
            "--start", str(ch), "--end", str(ch), "--skip-outline-review"]
    r = subprocess.run(args, cwd=str(ROOT), capture_output=True, encoding="utf-8", errors="replace", timeout=300)
    out = (r.stdout or "") + (r.stderr or "")
    ok = r.returncode == 0 and "[FAIL]" not in out and "FAIL:" not in out
    for line in out.split("\n"):
        if any(w in line for w in ["字数≈", "OK=", "总字数", "完成"]):
            print(f"    {line.strip()}")
    if not ok:
        for line in out.split("\n"):
            if "FAIL" in line or "Error" in line or "失败" in line:
                print(f"    {line.strip()[:120]}")
    return ok


def main():
    project = sys.argv[1] if len(sys.argv) > 1 else ""
    if not project:
        print("用法: python fangcun_golden3 <项目路径>")
        return

    config = find_config(project)
    print(f"黄金三章 — 逐章跑\n项目: {project}\nConfig: {config}")

    for ch in [1, 2, 3]:
        print(f"\n{'='*40}\n  第{ch}章\n{'='*40}")

        # Guides（只首次）
        print(f"\n  [1/2] 细纲...")
        run_phase(config, "guides", ch)

        # Write（失败重试最多2次）
        for attempt in range(1, 4):
            label = f"第{attempt}次" if attempt > 1 else "首次"
            print(f"\n  [2/2] 写章 ({label})...")
            if run_phase(config, "write", ch):
                # 检查字数
                chf = Path(project) / "chapters" / f"ch_{ch:03d}.txt"
                if chf.exists():
                    wc = len(chf.read_text(encoding="utf-8").replace("\n","").replace(" ",""))
                    if wc >= 500:
                        print(f"    ✓ 第{ch}章完成, {wc}字")
                        break
                    print(f"    ⚠️ 字数不足({wc}), 重试...")
            if attempt == 3:
                print(f"    ✗ 第{ch}章 3次重试均失败")

        # Compare
        print(f"\n  [审] 对比诊断...")
        run_phase(config, "compare", ch)

    # 最终统计
    cd = Path(project) / "chapters"
    files = sorted(cd.glob("ch_00[1-3].txt")) if cd.exists() else []
    total = sum(len(f.read_text(encoding="utf-8").replace("\n","").replace(" ","")) for f in files)
    print(f"\n{'='*40}\n  完成: {len(files)}/3章, {total:,}字\n{'='*40}")


if __name__ == "__main__":
    main()
