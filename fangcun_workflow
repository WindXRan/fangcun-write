#!/usr/bin/env python3
"""工作流执行器 — 把 AI 工具串成工作流。"""

import sys, json, subprocess, time
from pathlib import Path
import xml.etree.ElementTree as ET

ROOT = Path(__file__).parent
PIPE = str(ROOT / ".agents/skills/fangcun-write/tools/pipeline.py")
WF_DIR = ROOT / "ai_workflows"


def list_workflows():
    print("\n工作流:\n")
    for wf in sorted(WF_DIR.glob("*.xml")):
        tree = ET.parse(wf)
        root = tree.getroot()
        steps = len(root.findall("step"))
        print(f"  {wf.stem:20s}  {steps}步  {root.get('description', '')}")


def find_config(project: str) -> str:
    for cf in sorted((ROOT / "configs").glob("*.json")):
        cfg = json.loads(cf.read_text(encoding="utf-8"))
        rw = cfg.get("project_dir", "")
        if rw and rw in project:
            return str(cf)
    return "configs/test_10ch_v2.json"


def run_workflow(wf_name: str, project: str):
    wf_path = WF_DIR / f"{wf_name}.xml"
    if not wf_path.exists():
        print(f"工作流不存在: {wf_name}")
        return

    tree = ET.parse(wf_path)
    root = tree.getroot()
    config = find_config(project)

    print(f"\n{'='*50}")
    print(f"  {root.get('name')}")
    print(f"  项目: {project}")
    print(f"  步骤: {len(root.findall('step'))}")
    print(f"{'='*50}")

    t0 = time.time()
    for i, step in enumerate(root.findall("step"), 1):
        phase = step.get("phase")
        ch = step.get("chapter", "")
        start = step.get("start", ch)
        end = step.get("end", ch)
        retry = int(step.get("retry", "1"))

        if not start:
            # 书级 phase（无章节范围）
            print(f"\n  [{i}] {phase}...")
            args = ["python", PIPE, "--config", config, "--phase", phase,
                    "--skip-outline-review"]
            r = subprocess.run(args, cwd=str(ROOT), capture_output=True,
                             encoding="utf-8", errors="replace", timeout=600)
            ok = r.returncode == 0
        else:
            for attempt in range(1, retry + 1):
                label = f"第{attempt}次" if attempt > 1 else ""
                print(f"\n  [{i}] {phase} ch{start}-{end} {label}...")
                args = ["python", PIPE, "--config", config, "--phase", phase,
                        "--start", start, "--end", end, "--skip-outline-review"]
                r = subprocess.run(args, cwd=str(ROOT), capture_output=True,
                                 encoding="utf-8", errors="replace", timeout=300)
                out = (r.stdout or "") + (r.stderr or "")
                ok = r.returncode == 0

                for line in out.split("\n"):
                    if any(w in line for w in ["字数≈", "OK=", "完成", "✓"]):
                        print(f"    {line.strip()[:100]}")

                if ok:
                    break
                print(f"    ✗ 失败，重试...")

        if not ok:
            print(f"    ✗ {phase} 最终失败")
            return

    print(f"\n{'='*50}")
    print(f"  完成 ({time.time()-t0:.0f}s)")
    print(f"{'='*50}")


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("list", "ls"):
        list_workflows()
        return

    cmd = args[0]
    if cmd == "run":
        wf = args[1] if len(args) > 1 else ""
        project = ""
        i = 2
        while i < len(args):
            if args[i] in ("-p", "--project") and i + 1 < len(args):
                project = args[i + 1]; i += 2
            else:
                i += 1
        if not project:
            print("用法: python fangcun_workflow run <工作流名> -p <项目路径>")
            return
        run_workflow(wf, project)
    else:
        print("fangcun_workflow [list|run <name> -p <project>]")


if __name__ == "__main__":
    main()
