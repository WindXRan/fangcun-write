# 飞书配置示例文件
# 将此文件复制为 .env 并填入正确的值

# 飞书应用配置
# 在飞书开放平台创建应用后获取
FEISHU_APP_ID=your-app-id
FEISHU_APP_SECRET=your-app-secret

# 飞书表格配置
# 在飞书中创建在线表格后获取
FEISHU_SPREADSHEET_TOKEN=your-spreadsheet-token
FEISHU_SHEET_ID=your-sheet-id

# 使用说明：
# 1. 访问 https://open.feishu.cn/ 创建应用
# 2. 获取 App ID 和 App Secret
# 3. 在飞书中创建在线表格
# 4. 从表格URL获取 spreadsheet token
# 5. 右键点击工作表标签，复制工作表ID
# 6. 将此文件复制为 .env 并填入正确的值
# 7. 运行 python feishu_sync.py 测试同步