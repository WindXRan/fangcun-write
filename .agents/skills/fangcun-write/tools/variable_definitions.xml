<?xml version='1.0' encoding='utf-8'?>
<definitions>
  <categories>
    <category key="作品信息" label="作品信息" />
    <category key="大纲" label="大纲" />
    <category key="角色" label="角色" />
    <category key="正文" label="正文" />
    <category key="设定" label="设定" />
    <category key="自定义" label="自定义" />
  </categories>
  <variables>
    
    <variable name="当前章节号" category="正文" type="computed" source="runtime" handler="current_chapter" />
    <variable name="当前卷号" category="正文" type="computed" source="runtime" handler="current_volume" />
    <variable name="目标字数" category="正文" type="computed" source="computed" handler="target_words" />
    <variable name="总章数" category="作品信息" type="computed" source="computed" handler="total_chapters" />

    
    <variable name="补充要求" category="自定义" type="text" source="user_input" />
    <variable name="本章正文" category="正文" type="computed" source="computed" handler="本章正文" />
    <variable name="参考剧情" category="正文" type="text" source="user_input" />
    <variable name="源文对照" category="正文" type="computed" source="computed" handler="源文对照" />
    <variable name="前文章纲" category="大纲" type="computed" source="computed" handler="前文章纲">
      <description>自动读取上一章章纲。N=1时返回空（无上一章）。</description>
    </variable>
    <variable name="背景设定" category="设定" type="text" source="user_input" />
    <variable name="势力设定" category="设定" type="text" source="user_input" />
    <variable name="目标频道" category="作品信息" type="text" source="auto_extract">
      <extract from="作品信息/project.xml" method="xpath" xpath=".//channel" />
      <fallback>女频</fallback>
    </variable>
    <variable name="作品视角" category="作品信息" type="text" source="auto_extract">
      <extract from="作品信息/project.xml" method="xpath" xpath=".//perspective" />
      <fallback>第三人称</fallback>
    </variable>

    
    <variable name="protagonist_name" category="角色" type="computed" source="computed" handler="protagonist_name" />
    <variable name="antagonist_name" category="角色" type="computed" source="computed" handler="antagonist_name" />
    <variable name="ally_name" category="角色" type="computed" source="computed" handler="ally_name" />
    <variable name="本章角色" category="角色" type="computed" source="computed" handler="chapter_characters" />

    
    <variable name="关联章节" category="正文" type="computed" source="computed" handler="关联章节" />
    <variable name="关联章节号" category="正文" type="scalar" default="-1">
      <description>手动指定关联章节号。默认-1=自动取上一章；指定N=取第N章结尾。用于填补中间空缺章节时衔接前文。</description>
    </variable>
    <variable name="后续章节号" category="正文" type="scalar" default="0">
      <description>手动指定后续章节号。默认0=不读取；指定N=取第N章开头了解剧情走向。用于填补中间空缺章节时衔接后文。</description>
    </variable>
    <variable name="关联章纲" category="大纲" type="computed" source="computed" handler="关联章纲" />
    <variable name="关联角色" category="角色" type="computed" source="computed" handler="关联角色" />

    
    <variable name="故事名称" category="作品信息" type="text" source="auto_extract">
      <extract from="作品信息/project.xml" method="xpath" xpath=".//story_name" />
      <fallback>未命名</fallback>
    </variable>
    <variable name="源文书名" category="作品信息" type="text" source="auto_extract">
      <extract from="作品信息/project.xml" method="xpath" xpath=".//source_book" />
      <fallback>源文</fallback>
    </variable>

    
    <variable name="模板_简介" category="设定" type="computed" source="computed" handler="template_blurb" />
    <variable name="模板_总纲" category="设定" type="computed" source="computed" handler="template_story" />
    <variable name="模板_角色" category="设定" type="computed" source="computed" handler="template_entry" />
    <variable name="模板_标签" category="设定" type="computed" source="computed" handler="template_tags" />
    <variable name="模板_策略" category="设定" type="computed" source="computed" handler="template_adaptation" />
    <variable name="模板_细纲" category="设定" type="computed" source="computed" handler="template_章纲" description="已弃用，请使用 模板_章纲" />
    <variable name="模板_事件" category="设定" type="computed" source="computed" handler="template_events" />
    <variable name="模板_卷" category="设定" type="computed" source="computed" handler="template_volumes" />
    <variable name="模板_卷纲" category="设定" type="computed" source="computed" handler="template_卷纲" />
    <variable name="模板_章纲" category="设定" type="computed" source="computed" handler="template_章纲" />
        <variable name="模板_章纲_女频" category="设定" type="computed" source="computed" handler="template_章纲_女频" />
    <variable name="模板_写作规则" category="设定" type="computed" source="computed" handler="template_writing_rules" />
    <variable name="模板_钩子" category="设定" type="computed" source="computed" handler="template_hooks" />
    <variable name="模板_角色规则" category="设定" type="computed" source="computed" handler="template_character_rules" />
    <variable name="模板_标签池" category="设定" type="computed" source="computed" handler="template_tag_pool" />
    <variable name="模板_场景规则" category="设定" type="computed" source="computed" handler="template_scene_rules" />
    <variable name="模板_对比维度" category="设定" type="computed" source="computed" handler="template_compare_dimensions" />

    
    <variable name="设定" category="作品信息" type="computed" source="computed" handler="novel_setting">
      <description>聚合全部设定数据：角色/关系/地点/物品/势力/背景</description>
    </variable>

    <variable name="章节摘要" category="正文" type="computed" source="computed" handler="chapter_summaries">
      <description>全书章节摘要，供总纲/卷纲/套路分析使用。</description>
    </variable>

    <variable name="仿写模式" category="自定义" type="computed" source="computed" handler="fanxie_mode">
      <description>仿写模式标志。非空 = 仿写模式生效，空 = 原创模式。由 tool_executor 自动设置。</description>
    </variable>
  <variable name="频道模式" category="作品信息" type="computed" source="computed" handler="频道模式"><description>根据 project.xml 中 channel 自动返回男频或女频模式内容。</description></variable><variable name="标签" category="作品信息" type="file_ref" source="auto_extract"><extract from="作品信息/主题/标签.xml" method="read" /><description>@标签（自动读取）</description></variable><variable name="总纲" category="作品信息" type="file_ref" source="auto_extract"><extract from="作品信息/主题/总纲.xml" method="read" /><description>@总纲（自动读取）</description></variable><variable name="简介" category="作品信息" type="file_ref" source="auto_extract"><extract from="作品信息/主题/简介.xml" method="read" /><description>@简介（自动读取）</description></variable><variable name="卷纲" category="大纲" type="file_ref" source="auto_extract"><extract from="正文/卷纲/第1卷.xml" method="read" /><description>@卷纲（自动读取第1卷，已弃用，改用 @当前卷纲）</description></variable>
<variable name="当前卷纲" category="大纲" type="computed" source="computed" handler="当前卷纲"><description>@当前卷纲 — 根据当前章节号自动读取对应的卷纲文件。</description></variable><variable name="作品篇幅" category="作品信息" type="computed" source="computed" handler="作品篇幅"><description>返回作品篇幅描述</description></variable><variable name="角色列表" category="角色" type="computed" source="computed" handler="角色列表"><description>@角色列表 — 列出所有可用角色名，不依赖章纲。供 plot-guide 选择出场角色用。</description></variable><variable name="本章章纲" category="章纲" type="computed" source="computed" handler="本章章纲"><description>@本章章纲 — 读取当前章节的章纲文件。无章纲时报错。</description></variable><variable name="本卷章数" category="卷纲" type="computed" source="computed" handler="本卷章数"><description>@本卷章数 — 本卷总章数，自动从 start/end 计算：end - start + 1。</description></variable></variables>
</definitions>