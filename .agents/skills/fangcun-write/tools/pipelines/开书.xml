<?xml version="1.0" encoding="UTF-8"?>
<pipeline name="开书管线">
  <desc>开书全流程：脑洞→评估→映射→角色卡→验证</desc>

  <step tool="开书脑洞" id="brainstorm">
    <param name="模式" from="input.mode" />
    <param name="源文/方向" from="input.source" />
  </step>

  <step tool="开书评估" id="eval">
    <param name="方案" from="results.brainstorm.output" />
  </step>

  <step tool="world-mapper" id="mapper">
    <param name="方案编号" from="input.plan_id" />
    <param name="项目目录" from="project_dir" />
  </step>
</pipeline>
