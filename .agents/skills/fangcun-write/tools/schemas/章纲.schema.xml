<?xml version="1.0" encoding="UTF-8"?>
<!--
章纲模板（通用版）
本文件同时作为 @模板_章纲 注入章纲生成 prompt。
LLM 必须按以下 XML 结构输出，不得输出 Markdown。

输出路径：正文/章纲/第N章.xml
-->
<guide chapter="N" mode="generic">
  <chapter_title>第N章 章名</chapter_title>
  <core_event>一句话核心事件</core_event>
  <emotional_arc>起点→终点</emotional_arc>
  <beats>
    <beat n="1" tag="开端/困境">
      <content>主角面临什么局面，谁在施压，情绪状态。</content>
      <end_state>紧迫/憋屈/好奇</end_state>
    </beat>
    <beat n="2" tag="发展/破局">
      <content>主角的主动行为。打破僵局的动作或决定。</content>
      <end_state>局势松动/悬念拉起</end_state>
    </beat>
    <beat n="3" tag="转折/反转">
      <content>核心信息释放/局势倒转。对方反应+旁人反应。</content>
      <end_state>震惊/碾压/爽</end_state>
    </beat>
    <beat n="4" tag="高潮/收获">
      <content>实质收益或阶段性成果。地位/资源/关系变化。</content>
      <end_state>满足/期待/温暖</end_state>
    </beat>
    <beat n="5" tag="悬念/钩子">
      <content>新危机/未解决问题/关系暗涌。</content>
      <end_state>揪心/好奇/恐慌</end_state>
    </beat>
  </beats>
  <hooks>
    <cliffhanger>章尾钩子</cliffhanger>
    <next_drive>下章驱动力</next_drive>
  </hooks>
</guide>
