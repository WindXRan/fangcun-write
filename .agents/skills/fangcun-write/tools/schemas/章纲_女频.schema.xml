<?xml version="1.0" encoding="UTF-8"?>
<!--
章纲模板（女频版）
每段只写"发生了什么"，不写读者情绪、不写内心活动、不写对话。

段数规则：最少3段，最多8段。每段释放1-2条新事实。
-->
<guide chapter="N" mode="female">
  <chapter_title>第N章 章名</chapter_title>
  <core_event>一句话核心事件</core_event>
  <emotional_arc>起点→终点（如"焦虑→得意""绝望→燃起希望"）</emotional_arc>
  <opening_type>action|dialogue|suspense|emotion</opening_type>
  <tone>压抑|轻松|紧张|爽|温馨</tone>
  <beats>
    <beat n="1" tag="按功能自由标注">
      <content>发生了什么</content>
      <info_release>本beat释放的信息（≤2条事实）</info_release>
      <info_hold>本beat压住的信息（留到后面）</info_hold>
      <source_excerpt>贴2-3段原文——展示这段的段落节奏和OS位置</source_excerpt>
      <max_chars>200</max_chars>
    </beat>
    <beat n="2" tag="按功能自由标注">
      <content>发生了什么</content>
      <info_release>本beat释放的信息（≤2条事实）</info_release>
      <info_hold>本beat压住的信息（留到后面）</info_hold>
      <max_chars>200</max_chars>
    </beat>
    <beat n="3" tag="按功能自由标注">
      <content>...</content>
      <info_release>...</info_release>
      <info_hold>...</info_hold>
      <source_excerpt>...</source_excerpt>
      <max_chars>200</max_chars>
    </beat>
    <beat n="4" tag="">
      <content>...</content>
      <info_release>...</info_release>
      <info_hold>...</info_hold>
      <source_excerpt>...</source_excerpt>
      <max_chars>200</max_chars>
    </beat>
    <beat n="5" tag="">
      <content>...</content>
      <info_release>...</info_release>
      <info_hold>...</info_hold>
      <source_excerpt>...</source_excerpt>
      <max_chars>200</max_chars>
    </beat>
    <beat n="6" tag="">
      <content>...</content>
      <info_release>...</info_release>
      <info_hold>...</info_hold>
      <source_excerpt>...</source_excerpt>
      <max_chars>200</max_chars>
    </beat>
    <beat n="7" tag="">
      <content>...</content>
      <info_release>...</info_release>
      <info_hold>...</info_hold>
      <source_excerpt>...</source_excerpt>
      <max_chars>200</max_chars>
    </beat>
    <beat n="8" tag="">
      <content>...</content>
      <info_release>...</info_release>
      <info_hold>...</info_hold>
      <source_excerpt>...</source_excerpt>
      <max_chars>200</max_chars>
    </beat>
  </beats>
  <hooks>
    <cliffhanger>章尾具体钩子内容</cliffhanger>
    <hook_type>sudden_reveal|crisis|emotional_twist|cliffhanger|information_gap|choice|countdown</hook_type>
  </hooks>
  <characters>
    <character name="名" role="功能">本章作用一句话</character>
  </characters>
</guide>
