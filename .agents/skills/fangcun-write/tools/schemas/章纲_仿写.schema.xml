<?xml version="1.0" encoding="UTF-8"?>
<!--
章纲模板（仿写版）
只描述情绪目标+节奏+信息释放节奏，不描述具体事件。
content 字段为 function —— 只写"这段要达成什么情绪/功能"，不写"源文发生了什么"。
模型拿到章纲后必须自己设计事件来实现每个 function。
-->
<guide chapter="N" mode="fanxie">
  <chapter_title>第N章 章名</chapter_title>
  <core_event>本章核心功能描述（不写具体事件）</core_event>
  <emotional_arc>起点→终点</emotional_arc>
  <beats>
    <beat n="1" tag="开端/建立代入感">
      <function>让读者进入状态的方式（如：用主角内心吐槽建立喜剧感/用冲突建立压迫感）</function>
      <emotion>读者此刻情绪</emotion>
      <info_release>读者此刻知道什么信息</info_release>
    </beat>
    <beat n="2" tag="发展/制造期待">
      <function>这段要推进什么、让读者产生什么期待</function>
      <emotion>读者此刻情绪</emotion>
      <info_release>释放/压制什么信息</info_release>
    </beat>
    <beat n="3" tag="转折/引爆">
      <function>核心转折的功能目标</function>
      <emotion>读者此刻情绪</emotion>
      <info_release>读者此刻知道什么</info_release>
    </beat>
    <beat n="4" tag="高潮/释放">
      <function>高潮段的功能目标</function>
      <emotion>读者此刻情绪</emotion>
      <info_release>读者此刻知道什么</info_release>
    </beat>
    <beat n="5" tag="悬念/章尾">
      <function>章尾让读者产生什么期待</function>
      <emotion>读者此刻情绪</emotion>
      <info_release>悬念/未完成的信息</info_release>
    </beat>
  </beats>
  <hooks>
    <cliffhanger>章尾钩子</cliffhanger>
    <next_drive>下章驱动力</next_drive>
  </hooks>
</guide>
