<?xml version="1.0" encoding="UTF-8"?>
<!--
  pattern.schema.xml — 套路分析模板。
  存储于 作品信息/套路分析.xml。
  提取源文的套路流派本质，供仿写重建使用。
  仿写管线中所有下游工具只看此文件，不看源文原文。
-->
<pattern_analysis>
  <!-- 流派定位 -->
  <genre primary="都市" sub="身份错位">题材大类</genre>

  <!-- 核心爽点公式 -->
  <core_appeal>
    <formula>爽点公式，如：身份错位 + 信息差 + 连续打脸</formula>
    <reader_drive>读者追更的核心动力，一句话</reader_drive>
  </core_appeal>

  <!-- 节奏节点（核心：读者旅程时间线） -->
  <rhythm_nodes>
    <node position="1-14行">
      <function>让读者看到一个"不对劲的世界"</function>
      <reader_emotion_start>平淡</reader_emotion_start>
      <reader_emotion_end>好奇</reader_emotion_end>
      <vehicle>环境+道具</vehicle>
      <info_release>这个节点释放的信息（只写"刚好满足当前场景"的量）</info_release>
      <info_hold_back>这个节点刻意不说的信息（留给后面节点释放）</info_hold_back>
      <why_works>为什么这个节点能抓住读者</why_works>
    </node>
    <node position="15-58行">
      <function>通过角色对话理解世界规则</function>
      <reader_emotion_start>好奇</reader_emotion_start>
      <reader_emotion_end>期待</reader_emotion_end>
      <vehicle>对话(≥3组角色)</vehicle>
      <info_release>世界分级+规则</info_release>
      <why_works>读者"偷听"角色对话自然了解设定</why_works>
    </node>
    <node position="59-68行">
      <function>让读者意识到这是生死大事</function>
      <reader_emotion_start>期待</reader_emotion_start>
      <reader_emotion_end>压抑</reader_emotion_end>
      <vehicle>广角描写</vehicle>
      <info_release>死亡率是真实的</info_release>
      <why_works>从对话切全景，节奏停顿制造压迫感</why_works>
    </node>
    <node position="69-88行">
      <function>让读者和主角同步发现穿越</function>
      <reader_emotion_start>压抑</reader_emotion_start>
      <reader_emotion_end>困惑</reader_emotion_end>
      <vehicle>内心独白</vehicle>
      <info_release>主角是穿越者+两套记忆</info_release>
      <why_works>读者和主角信息同步，一起探索</why_works>
    </node>
    <node position="89-143行">
      <function>完整理解世界体系</function>
      <reader_emotion_start>困惑</reader_emotion_start>
      <reader_emotion_end>理解</reader_emotion_end>
      <vehicle>内心独白+说明</vehicle>
      <info_release>完整规则+主角背景</info_release>
      <why_works>前期建立的好奇在此释放，读者不觉得累</why_works>
    </node>
    <node position="144-167行">
      <function>建立最终悬念</function>
      <reader_emotion_start>理解</reader_emotion_start>
      <reader_emotion_end>紧张</reader_emotion_end>
      <vehicle>权威角色讲话</vehicle>
      <info_release>死亡警告+不要选XX</info_release>
      <why_works>读者期待主角打破规则</why_works>
    </node>
  </rhythm_nodes>

  <!-- 角色功能拓扑 -->
  <role_topology>
    <role function="主角-伪装者" arc="底层伪装→身份做实→真强大" mandatory="true"/>
    <role function="对手-质疑者" arc="质疑→被打脸→被收服/消失" mandatory="true"/>
    <role function="辅助-信以为真者" arc="相信→怀疑→再相信"/>
  </role_topology>

  <!-- 冲突类型分布 -->
  <conflict_distribution>
    <conflict type="身份冲突" percentage="60"/>
    <conflict type="利益冲突" percentage="25"/>
    <conflict type="信息差冲突" percentage="15"/>
  </conflict_distribution>

  <!-- 情绪弧线模板（按章） -->
  <emotional_template>
    <chapter n="1">压抑→爆发→爽→得意→欲望</chapter>
    <chapter n="2">轻松→危机→紧张→打脸→满足</chapter>
  </emotional_template>

  <!-- 章节结构模板 -->
  <chapter_structure>
    <element name="开场冲突" position="1-10行" mandatory="true">读者立刻知道主角面临什么压力</element>
    <element name="冲突升级" position="10-30%" mandatory="true">压力持续增加或叠加新压力</element>
    <element name="转折" position="30-50%" mandatory="true">信息/关系/局势发生变化</element>
    <element name="打脸/高潮" position="50-70%" mandatory="true">情绪峰值或动作峰值</element>
    <element name="收获+钩子" position="70-100%" mandatory="true">阶段性收益 + 下文推力</element>
  </chapter_structure>

  <!-- 信息释放节奏 -->
  <info_release>
    <point position="开场">读者知道的关键事实</point>
    <point position="第30行">读者知道的关键事实</point>
    <point position="第50行">读者知道的关键事实</point>
    <point position="第70行">读者知道的关键事实</point>
    <point position="第100行">读者知道的关键事实</point>
    <point position="章尾">读者知道的关键事实</point>
  </info_release>
</pattern_analysis>
