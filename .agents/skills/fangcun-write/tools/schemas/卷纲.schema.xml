<?xml version="1.0" encoding="UTF-8"?>
<!--
卷纲模板（XML 格式）
本文件同时作为 @模板_卷纲 注入卷纲生成 prompt，
LLM 必须按以下 XML 结构输出，不得写泛泛的描述。

输出路径：正文/卷纲/第X卷_卷名.xml
-->
<volume id="1" name="卷名">
  <goal>本卷结束时的剧情状态（主角达到什么位置）</goal>
  <description>一段话概括本卷：时代背景约束 + 主角核心困境 + 情绪基调 + 驱动力</description>
  <emotional_arc>压抑→蓄势→爆发→余韵</emotional_arc>
  <key_events>
    <event order="1" title="幕名">
      <content>谁做了什么、为什么做、结果如何。关键事件和转折融入叙事中。</content>
      <function>剧情功能标签</function>
    </event>
    <event order="2" title="幕名">
      <content>...</content>
      <function>功能标签</function>
    </event>
    <event order="3" title="幕名">
      <content>...</content>
      <function>功能标签</function>
    </event>
  </key_events>
  <characters>
    <character name="角色名" role="功能位">身份背景+性格要点+本卷变化弧线</character>
    <character name="角色名" role="功能位">...</character>
  </characters>
  <climax>本卷高潮反转</climax>
  <hook>下一卷伏笔/悬念</hook>
</volume>
