<?xml version="1.0" encoding="UTF-8"?>
<!--
  events.schema.xml — 事件表条目模板。
  用于追踪逐章的核心事件、情绪弧线和跨章因果。
  同时作为 @模板_事件 注入提取 prompt。
-->
<events>
  <event id="1" volume="1" arc="弧线名称">
    <core_event>主角做了什么，结果如何（30-60字）</core_event>
    <opening>冷开/承：上章结尾的衔接</opening>
    <ending_state>本章结束时主角/局势的状态</ending_state>
    <bridge>→ 下章承接方向</bridge>
    <emotional_arc>基调→基调→基调（3-5段）</emotional_arc>
    <characters>有实际戏份的角色，顿号分隔</characters>
    <main_plot>本章对主线的推进</main_plot>
    <subplot_state>各支线的当前状态</subplot_state>
    <info_release>本章释放的新信息/伏笔</info_release>
    <character_change>角色的战力/心境/立场变化</character_change>
    <cross_chapter_causality>与前后章的因果关系</cross_chapter_causality>
  </event>
</events>
