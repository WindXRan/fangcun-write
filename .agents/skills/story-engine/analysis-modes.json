{
  "modes": {
    "style": {
      "template": "prompts/style-analysis-task.md",
      "output_pattern": "style_guide_{N}.md",
      "output_dir": "蒸馏/mode-b",
      "description": "inkos 8维度文风分析",
      "enabled": true
    },
    "hook": {
      "template": "prompts/hook-analysis-task.md",
      "output_pattern": "hook_guide_{N}.md",
      "output_dir": "蒸馏/mode-b",
      "description": "钩子工程学：段落钩子、章首钩子、章末钩子、情绪钩子、信息钩子、反预期钩子",
      "enabled": true
    },
    "character": {
      "template": "prompts/character-analysis-task.md",
      "output_pattern": "character_guide_{N}.md",
      "output_dir": "蒸馏/mode-b",
      "description": "角色塑造：立体感、性格外化、角色差异化、配角塑造、关系张力、成长暗示",
      "enabled": true
    }
  },
  "defaults": {
    "batch_size": 10,
    "word_count_min": 2000,
    "word_count_max": 2500,
    "word_count_hard_limit": 3000
  }
}
