# ── 内联 load_presets（原 tool_runner）───────────────────

_BUILTIN_DIR = TOOLS_DIR / "builtin"

def load_presets() -> list[dict]:
    """扫描 builtin/ 加载所有 .xml preset 文件。支持目录/preset.xml 和 扁平 .xml。"""
    import xml.etree.ElementTree as ET
    presets = []

    def _parse(root, pid):
        sp = ""
        prompt_el = root.find("prompt")
        if prompt_el is not None and prompt_el.text:
            sp = prompt_el.text.strip()
        return {
            "id": pid, "name": root.findtext("name", pid),
            "icon": root.findtext("icon", "?"), "category": root.findtext("category", "其他"),
            "phase": root.findtext("phase", ""), "temp": float(root.findtext("temperature", "0.7")),
            "desc": root.findtext("description", ""), "opening": root.findtext("opening", ""),
            "output": root.findtext("output", ""), "sp": sp,
            "variables": [v.strip() for v in root.findtext("variables", "").split(",") if v.strip()],
            "source": "builtin",
        }

    # 扁平 .xml 文件（id = 文件名去.xml）
    if _BUILTIN_DIR.exists():
        for f in sorted(_BUILTIN_DIR.glob("*.xml")):
            pid = f.stem
            if pid == "system-prompt": continue  # 系统级，不作为预设暴露
            try:
                tree = ET.parse(f)
                presets.append(_parse(tree.getroot(), pid))
            except Exception:
                pass

    # 目录/preset.xml（自定义工具）
    if CUSTOM_DIR.exists():
        for tool_dir in sorted(CUSTOM_DIR.iterdir()):
            if not tool_dir.is_dir(): continue
            preset_xml = tool_dir / "preset.xml"
            if not preset_xml.exists(): continue
            try:
                tree = ET.parse(preset_xml)
                presets.append({**_parse(tree.getroot(), tool_dir.name), "source": "custom"})
            except Exception:
                pass

    return presets


def save_output_files(text: str, project_dir: str) -> list[str]:
    """扫描 LLM 输出中的 `==== path ====` 标记，保存到对应文件。"""
    import re as _re
    import xml.etree.ElementTree as ET
    saved = []
    has_char = False
    for m in _re.finditer(r'====\s*([^\n=]+)\s*====\s*\n(.*?)(?=\n====|\Z)', text, _re.DOTALL):
        path = m.group(1).strip()
        content = m.group(2).strip()
        if not path or not content:
            continue
        fp = Path(project_dir) / path
        fp.parent.mkdir(parents=True, exist_ok=True)
        fp.write_text(content, encoding='utf-8')
        saved.append(path)
    return saved


def execute_tool(name: str, args: dict, project_dir: str) -> str:
