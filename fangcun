def detect_preset(user_input: str) -> str:
    for preset_id, keywords in PRESET_KEYWORDS.items():
        for kw in keywords:
            if kw in user_input:
                return preset_id
    return "chat-assistant"


# ═══════════════════════ LLM ═══════════════════════

def call_llm(messages: list, temperature: float = 0.7):
    api_key = os.environ.get("API_KEY", "")
    if not api_key or not api_key.startswith("sk-"):
        api_key = os.environ.get("ANTHROPIC_AUTH_TOKEN", api_key)
    _base = os.environ.get("API_BASE_URL", "https://api.deepseek.com/v1").rstrip("/")
    if not _base.endswith("/v1"):
        _base += "/v1"
    api_url = _base + "/chat/completions"
    model = os.environ.get("FANGCUN_MODEL", "deepseek-chat")
    if not api_key:
        return None, "未设置 API_KEY"

    body = json.dumps({"model": model, "messages": messages, "temperature": temperature, "max_tokens": 4096}).encode()
    req = Request(api_url, data=body, headers={"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"})
    try:
        with urlopen(req, timeout=180) as r:
            return json.loads(r.read())["choices"][0]["message"]["content"], None
    except Exception as e:
        return None, str(e)


# ═══════════════════════ 核心执行 ═══════════════════════

def run(project_dir: str, user_input: str, preset_id: str = None, verbose: bool = True):
    """执行一次 Agent Turn。返回 (response_text, tool_results)。"""
    if preset_id is None:
        preset_id = detect_preset(user_input)

    presets = load_presets()
    preset = next((p for p in presets if p["id"] == preset_id), presets[0])

    # 变量解析
    resolver = VariableResolver(project_dir)
    ch_match = re.search(r'第\s*(\d+)', user_input)
    N = int(ch_match.group(1)) if ch_match else 1
    resolver.set_context(N=N, start=max(1, N-5), end=N)

    sp = resolver.render(preset["sp"])

    messages = [
        {"role": "system", "content": sp},
        {"role": "user", "content": user_input},
    ]

    if verbose:
        book = resolver.resolve("故事名称")
        print(f"\n{'═' * 50}")
        print(f"  {preset['icon']} {preset['name']}  |  {book}")
        print(f"  {user_input}")
        print(f"{'═' * 50}\n")

    resp, err = call_llm(messages, preset["temp"])
    if err:
        print(f"  ❌ {err}")
        return err, []

    # 自动保存文件
    saved = save_output_files(resp, project_dir)
    if not saved:
        # 单文件工具：无标记时直接保存到预设路径
        _single_map = {
            "synopsis-generate": "作品信息/主题/简介.xml",
            "outline-generate": "作品信息/主题/总纲.xml",
            "tags-generate": "作品信息/主题/标签.xml",
        }
        if preset_id in _single_map:
            fp = Path(project_dir) / _single_map[preset_id]
            fp.parent.mkdir(parents=True, exist_ok=True)
            fp.write_text(resp, encoding='utf-8')
            saved = [_single_map[preset_id]]
        elif preset_id in ("write-chapter", "golden-opening"):
            m = re.search(r'第(\d+)', user_input)
            ch = int(m.group(1)) if m else 1
            fp = Path(project_dir) / f"正文/正文/第{ch}章.xml"
            fp.parent.mkdir(parents=True, exist_ok=True)
            fp.write_text(f'<chapter number="{ch}"><content>\n{resp}\n  </content></chapter>', encoding='utf-8')
            saved = [f"正文/正文/第{ch}章.xml"]
        elif preset_id in ("character-generate", "character-designer") and ("<entry" in resp or "<character" in resp):
            import re as _re
            # 清理 markdown 包裹
            clean = _re.sub(r'```(?:xml)?\n?', '', resp).strip()
            m = _re.search(r'name="([^"]+)"', clean)
            name = m.group(1) if m else "未知角色"
            fp = Path(project_dir) / f"作品信息/设定/角色/{name}.xml"
            fp.parent.mkdir(parents=True, exist_ok=True)
            fp.write_text(clean, encoding='utf-8')
            saved = [f"作品信息/设定/角色/{name}.xml"]
        elif preset_id == "plot-guide" and "<guide" in resp:
            m = re.search(r'第(\d+)', user_input)
            ch = int(m.group(1)) if m else 1
            fp = Path(project_dir) / f"正文/章纲/第{ch}章.xml"
            fp.parent.mkdir(parents=True, exist_ok=True)
            fp.write_text(resp, encoding='utf-8')
            saved = [f"正文/章纲/第{ch}章.xml"]
    if saved and verbose:
        print(f"  📁 保存 {len(saved)} 个文件")

    # 执行工具
    tool_results = []
    clean = resp

    if verbose and clean:
        print(f"\n{clean}\n")

    return clean, tool_results


# ═══════════════════════ main ═══════════════════════

def init_project(project_dir: str) -> str:
    """创建新项目目录结构。返回项目路径。"""
    p = Path(project_dir)
    p.mkdir(parents=True, exist_ok=True)
    # 目录结构
    for d in ["正文/卷纲", "正文/章纲", "正文/正文",
              "作品信息/设定/角色", "作品信息/设定/背景",
              "作品信息/设定/势力", "作品信息/设定/地点",
              "作品信息/设定/物品", "作品信息/主题"]:
        (p / d).mkdir(parents=True, exist_ok=True)
    print(f"\n  📁 新建项目: {project_dir}")
    return str(p)


def main():
    import argparse
    p = argparse.ArgumentParser(description="方寸写作 — 全自动 CLI")
    p.add_argument("message", nargs="*", help="自然语言指令")
    p.add_argument("-p", "--project", default="", help="项目路径（留空=自动检测）")
    p.add_argument("--preset", default="", help="工具预设（留空=自动匹配）")
    p.add_argument("--list", action="store_true", help="列出预设和工具")
    p.add_argument("--status", action="store_true", help="显示项目状态")
    opts = p.parse_args()

    user_input = " ".join(opts.message) if opts.message else ""

    # --list
    if opts.list:
        print("\nAI 工具:\n")
        for pr in load_presets():
            tag = "内置" if pr.get("source") == "builtin" else "自定义"
            cat = pr.get("category", "其他")
            out = pr.get("output", "")
            out_str = f" → {out}" if out else ""
            print(f"  {pr['icon']} {pr['name']:8s} [{cat}] ({pr['id']:20s})  temp={pr['temp']}{out_str}")
        if CUSTOM_DIR.exists() and not list(CUSTOM_DIR.iterdir()):
            print(f"\n  自定义 AI 工具: {CUSTOM_DIR}")
            print(f"  放一个新目录含 preset.xml 即可")
        return

    # 检测项目
    project_dir = opts.project or detect_project()

    # --status
    if opts.status or not user_input:
        if not project_dir:
            print("未找到项目。请设 FANGCUN_PROJECT 环境变量，或放在 configs/ 或 projects/ 下。")
            return
        r = VariableResolver(project_dir)
        r.set_context(N=1)
        book = r.resolve("故事名称")
        chapters_dir = Path(project_dir) / "chapters"
        ch_count = len(list(chapters_dir.glob("第*章*.txt"))) + len(list(chapters_dir.glob("ch_*.txt"))) if chapters_dir.exists() else 0
        print(f"\n  书名: {book}")
        print(f"  项目: {project_dir}")
        print(f"  章节: {ch_count} 章")
        print(f"  状态: {'就绪' if ch_count > 0 else '待开书'}")
        if not user_input:
            return

    if not project_dir:
        # 开书/设定类指令 → 自动建项目
        if user_input:
            _p = detect_preset(user_input)
            if _p in ("book-draw", "character-generate", "setting-generate", "plot-guide", "character-extract"):
                project_dir = str(PROJECT_ROOT / "projects" / "新作品")
                init_project(project_dir)
        if not project_dir:
            print("未找到项目。fangcun -p <项目路径> \"指令\"")
            return

    preset_id = opts.preset or (detect_preset(user_input) if user_input else "chat-assistant")
    run(project_dir, user_input, preset_id)


if __name__ == "__main__":
    main()
