        resolver = VariableResolver(project_dir)
        resolver.set_context(N=1)
        template = resolver.resolve("template_volumes")
        prompt = f"""按以下模板生成卷纲，每卷用 `==== 正文/卷纲/第X卷.xml ====` 分隔：

{template}

总章数：{args.get('total_chapters', 192)}"""
        text, _ = call_llm([{"role": "user", "content": prompt}])
        if text:
            saved = save_output_files(text, project_dir)
            return f"卷纲生成完成: {', '.join(saved)}"
        return "卷纲生成失败"
    elif name == "generate_plot_guide":
