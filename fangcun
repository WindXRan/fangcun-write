        return "原创开书失败"
    return f"未知工具: {name}"


# ═══════════════════════ 自动检测项目 ═══════════════════════

def detect_project():
    """自动检测项目目录。优先级：环境变量 > configs/ > projects/ > ."""
    # 1. 环境变量
    env = os.environ.get("FANGCUN_PROJECT", "")
    if env and Path(env).exists():
        return env

    # 2. 从 configs/ 找
    configs_dir = PROJECT_ROOT / "configs"
    if configs_dir.exists():
        cfgs = sorted(configs_dir.glob("*.json"))
        if cfgs:
            cfg = json.loads(cfgs[0].read_text(encoding="utf-8"))
            rw = cfg.get("project_dir", "")
            if rw:
                p = Path(rw)
                if not p.is_absolute():
                    p = PROJECT_ROOT / p
                if p.exists():
                    return str(p)

    # 3. 从 projects/ 找有内容的项目目录
    projects_dir = PROJECT_ROOT / "projects"
    if projects_dir.exists():
        for author in projects_dir.iterdir():
            if not author.is_dir(): continue
            for book in author.iterdir():
                if not book.is_dir(): continue
                for rw in book.iterdir():
                    if not rw.is_dir(): continue
                    has_any = any((rw / f).exists() for f in ("events.xml", "concept.md", "book_info.md"))
                    if has_any:
                        return str(rw)

    # 4. 当前目录
    cwd = Path.cwd()
    if (cwd / "concept.md").exists():
        return str(cwd)

    return ""


