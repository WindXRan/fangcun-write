            save_chapter_file(project_dir, ch, text)
        return f"第{ch}章完成, {len(text)}字"
    elif name == "trim_chapter":
        trim_chapter(config, args.get("chapter_number", 1))
        return "已压缩"
    elif name == "expand_chapter":
        expand_chapter(config, args.get("chapter_number", 1))
        return "已扩展"
    elif name == "save_files":
